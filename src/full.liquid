<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700;800;900&family=Inter:wght@400;500;600;700;800&display=swap');

.cal-root *{ margin:0; padding:0; box-sizing:border-box; }
html, body{ margin:0 !important; padding:0 !important; background:#fff !important; height:100% !important; }
.environment, .screen, .view, .view--full{ padding:0 !important; margin:0 !important; height:auto !important; min-height:0 !important; max-height:none !important; overflow:visible !important; }
.cal-root{
  position:relative; width:780px; height:1040px; overflow:hidden;
  background:#fff; color:#111;
  font-family:'Inter',sans-serif;
  padding:14px 17px; display:flex; flex-direction:column;
  --muted:#444444; --rule:#000000; --rule-strong:#000000; --today:#e2e2e2; --date-col-width:43px;
}
.cal-root svg{ display:block; }

/* header */
.cal-root .header{ display:flex; border-bottom:1.5px solid #111; padding-bottom:8px; }
.cal-root .header-left{ flex:1; padding-right:14px; }
.cal-root .eyebrow{ font-size:12px; letter-spacing:.34em; text-transform:uppercase; color:var(--muted); font-weight:600; }
.cal-root .masthead{ display:flex; align-items:baseline; gap:14px; margin-top:3px; }
.cal-root .mon{ font-family:'Playfair Display',serif; font-weight:800; font-size:50px; line-height:.9; letter-spacing:-.01em; }
.cal-root .yr{ font-family:'Playfair Display',serif; font-weight:500; font-size:27px; color:var(--muted); line-height:.9; }
.cal-root .header-right{ width:211px; border-left:1.5px solid #111; padding-left:14px; display:flex; flex-direction:column; justify-content:center; }
.cal-root .wx-city{ font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); text-align:right; line-height:1.25; font-weight:600; }
.cal-root .wx-mainline{ display:flex; align-items:center; justify-content:flex-end; gap:8px; margin-top:4px; }
.cal-root .wx-textblock{ text-align:right; }
.cal-root .wx-hl{ font-size:15px; font-weight:700; }
.cal-root .wx-sun{ display:flex; justify-content:flex-end; gap:8px; margin-top:4px; }
.cal-root .wx-sun-item{ display:flex; align-items:center; gap:3px; font-size:9px; color:var(--muted); font-weight:600; white-space:nowrap; }
.cal-root .wx-big{ font-family:'Playfair Display',serif; font-weight:800; font-size:51px; line-height:.8; }
.cal-root .wx-big sup{ font-size:19px; font-weight:700; vertical-align:super; }
.cal-root .wx-unavailable{ font-family:'Playfair Display',serif; font-weight:700; font-size:20px; line-height:1.1; color:var(--muted); }
.cal-root .wx-ico{ width:24px; height:24px; }
.cal-root .wx-ico svg{ width:100%; height:100%; }

/* grid */
.cal-root .grid{ flex:1; display:flex; flex-direction:column; min-height:0; }
.cal-root .row{ display:grid; grid-template-columns:var(--date-col-width) repeat(5,1fr); border-bottom:1.3px solid var(--rule); }
.cal-root .row > *{ border-right:1.3px solid var(--rule); }
.cal-root .row > *:last-child{ border-right:none; }
.cal-root .grid-head{ border-bottom:1.5px solid var(--rule-strong); }
.cal-root .grid-head .date-cell{ display:flex; align-items:center; justify-content:center; padding-left:0; }
.cal-root .gh-date{ font-size:10px; letter-spacing:.18em; color:var(--muted); font-weight:600; }
.cal-root .person-head{ display:flex; align-items:center; justify-content:center; text-align:center; padding:6px 4px; font-size:13px; font-weight:700; line-height:1.1; }
.cal-root .grid-body{ position:relative; flex:1; display:grid; grid-auto-rows:minmax(0,1fr); min-height:0; overflow:visible; }
.cal-root .date-cell{ display:flex; align-items:center; gap:4px; padding-left:7px; }
.cal-root .dow{ font-size:10px; color:var(--muted); font-weight:600; min-width:7px; }
.cal-root .dnum{ font-family:'Playfair Display',serif; font-size:19px; font-weight:600; line-height:1; }
.cal-root .row.month-start{ border-top:2px solid #111; }
.cal-root .row.month-start .dow{ color:#111; font-weight:800; }
.cal-root .cell{ padding:3px 7px 3px 18px; display:flex; flex-direction:column; justify-content:center; gap:2px; overflow:visible; }
.cal-root .cell.has-span-bar{ padding-left:27px; }
.cal-root .evt{ font-size:12.5px; font-weight:600; line-height:1.18; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
.cal-root .evt .t{ font-size:11px; color:var(--muted); font-weight:600; margin-right:3px; }
.cal-root .is-today{ background:var(--today); }
.cal-root .is-today .dnum{ font-weight:700; }
.cal-root .span-bar{ position:absolute; box-sizing:border-box; width:20px; border:1.3px solid #111; background:#f2f2f2; border-radius:3px; display:flex; align-items:center; justify-content:center; writing-mode:vertical-rl; transform:rotate(180deg); font-size:12.5px; font-weight:600; letter-spacing:.05em; text-transform:uppercase; overflow:hidden; padding:4px 2px; z-index:2; }

.cal-root .row.has-holiday{ grid-template-rows:auto 1fr; }
.cal-root .holiday-banner{ position:relative; grid-column:1 / -1; display:flex; align-items:center; justify-content:center; gap:5px; padding:2px 8px; font-size:12.5px; font-weight:600; letter-spacing:.08em; text-transform:uppercase; background:var(--today); border-bottom:1px solid #111; }

/* ---- stickers: bold icons that bleed a little past their own cell/row, hand-placed feel ---- */
.cal-root .sticker{ position:absolute; z-index:8; pointer-events:none; filter: drop-shadow(0 0 2px #fff) drop-shadow(0 0 2px #fff) drop-shadow(0 0 1.5px #fff); }
.cal-root .sticker svg{ width:100%; height:100%; display:block; }

/* footer */
.cal-root .footer{ display:flex; align-items:center; justify-content:space-between; border-top:1.5px solid #111; padding-top:6px; margin-top:1px; font-size:9px; color:var(--muted); letter-spacing:.04em; }
.cal-root .footer .right{ display:flex; align-items:center; gap:6px; }
.cal-root .dev-glyph{ width:14px; height:9px; border:1px solid var(--muted); border-radius:2px; }
</style>

