<div class="cal-root">

  <!-- ============ HEADER ============ -->
  <div class="header">
    <div class="header-left">
      <div class="eyebrow">Family Calendar</div>
      {%- assign range_first = days | first -%}
      {%- assign range_last = days | last -%}
      {%- if range_first.month_name == range_last.month_name -%}
        {%- capture range_display -%}{{ range_first.month_name }} {{ range_first.d }}&ndash;{{ range_last.d }}{%- endcapture -%}
      {%- else -%}
        {%- assign range_fm = range_first.month_name | slice: 0, 3 -%}
        {%- assign range_lm = range_last.month_name | slice: 0, 3 -%}
        {%- capture range_display -%}{{ range_fm }} {{ range_first.d }} &ndash; {{ range_lm }} {{ range_last.d }}{%- endcapture -%}
      {%- endif -%}
      <div class="masthead"><span class="mon">{{ range_display }}</span><span class="yr">{{ meta.year }}</span></div>
    </div>
    <div class="header-right">
      <div class="wx-city">{{ location }}</div>
      <div class="wx-mainline">
        <div class="wx-textblock">
          {%- if current.available -%}
          <div class="wx-hl">H {{ current.high }}&deg;&nbsp;&nbsp;L {{ current.low }}&deg;</div>
          {%- endif -%}
          {%- if current.sunrise and current.sunset -%}
          <div class="wx-sun">
            <span class="wx-sun-item"><svg viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="width:11px;height:11px"><path d="M3 19 H21"/><path d="M7.5 19 A4.5 4.5 0 0 1 16.5 19"/><path d="M5.2 16.2 L4 15"/><path d="M18.8 16.2 L20 15"/><path d="M12 12 V5.8"/><path d="M9.4 8.4 L12 5.8 L14.6 8.4"/></svg><span>{{ current.sunrise }}</span></span>
            <span class="wx-sun-item"><svg viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="width:11px;height:11px"><path d="M3 19 H21"/><path d="M7.5 19 A4.5 4.5 0 0 1 16.5 19"/><path d="M5.2 16.2 L4 15"/><path d="M18.8 16.2 L20 15"/><path d="M12 5.8 V12"/><path d="M9.4 9.4 L12 12 L14.6 9.4"/></svg><span>{{ current.sunset }}</span></span>
          </div>
          {%- endif -%}
        </div>
        {%- if current.available -%}
        <div class="wx-big">{{ current.temp }}<sup>&deg;</sup></div>
        <div class="wx-ico">{% case current.icon %}{% when 'sun' %}{{ ic_sun }}{% when 'partly' %}{{ ic_partly }}{% when 'rain' %}{{ ic_rain }}{% when 'storm' %}{{ ic_storm }}{% when 'snow' %}{{ ic_snow }}{% else %}{{ ic_cloud }}{% endcase %}</div>
        {%- else -%}
        <div class="wx-unavailable">Weather<br/>unavailable</div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- ============ GRID ============ -->
  {%- comment -%}
    Detect runs of consecutive days, per column, where some event's title
    (ignoring a trailing " (n/n)" counter suffix) repeats -- these render as one
    spanning bar instead of a repeated line on every day. Every event in a day
    is checked (not just the first) so a same-day, differently-sorted event
    (e.g. "Pay Day" landing before "Summer Camp" that day) can't break the run
    early. Results are flattened into col-major arrays
    (index = col_index*days.size + day_index) since Liquid can't mutate arrays
    in place.
  {%- endcomment -%}
  {%- assign span_is_cont = "" -%}
  {%- assign span_len_all = "" -%}
  {%- assign span_match_idx = "" -%}
  {%- assign last_day_idx = days.size | minus: 1 -%}
  {%- for col in columns -%}
    {%- assign prev_base = "" -%}
    {%- for day in days -%}
      {%- assign d_idx = forloop.index0 -%}
      {%- assign devs = day.ev[col] -%}

      {%- assign found_idx = -1 -%}
      {%- if prev_base != "" -%}
        {%- for ev in devs -%}
          {%- assign ev_base = ev[1] | split: " (" | first | strip -%}
          {%- if ev_base == prev_base and found_idx == -1 -%}
            {%- assign found_idx = forloop.index0 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if found_idx != -1 -%}
        {%- assign span_is_cont = span_is_cont | append: "1," -%}
        {%- assign span_match_idx = span_match_idx | append: found_idx | append: "," -%}
        {%- assign span_len_all = span_len_all | append: "0," -%}
      {%- else -%}
        {%- assign span_is_cont = span_is_cont | append: "0," -%}
        {%- assign span_match_idx = span_match_idx | append: "0," -%}
        {%- if devs.size > 0 -%}
          {%- assign base = devs[0][1] | split: " (" | first | strip -%}
        {%- else -%}
          {%- assign base = "" -%}
        {%- endif -%}
        {%- assign L = 1 -%}
        {%- if base != "" and d_idx < last_day_idx -%}
          {%- assign next_idx = d_idx | plus: 1 -%}
          {%- for j in (next_idx..last_day_idx) -%}
            {%- assign nday = days[j] -%}
            {%- assign nevs = nday.ev[col] -%}
            {%- assign n_hit = false -%}
            {%- for nev in nevs -%}
              {%- assign nev_base = nev[1] | split: " (" | first | strip -%}
              {%- if nev_base == base -%}
                {%- assign n_hit = true -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if n_hit -%}
              {%- assign L = L | plus: 1 -%}
            {%- else -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
        {%- assign span_len_all = span_len_all | append: L | append: "," -%}
        {%- assign prev_base = base -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endfor -%}
  {%- assign span_is_cont_arr = span_is_cont | split: "," -%}
  {%- assign span_len_arr = span_len_all | split: "," -%}
  {%- assign span_match_idx_arr = span_match_idx | split: "," -%}

  <div class="grid">
    <div class="row grid-head">
      <div class="date-cell"><span class="gh-date">DATE</span></div>
      {%- for col in columns -%}
      <div class="person-head">{{ col }}</div>
      {%- endfor -%}
    </div>
    <div class="grid-body">
      {%- for day in days -%}
      {%- assign d_idx = forloop.index0 -%}
      {%- assign has_holiday = false -%}
      {%- assign holiday_text = "" -%}
      {%- if day.holiday.size > 0 -%}
        {%- assign has_holiday = true -%}
        {%- assign holiday_text = day.holiday | join: " · " -%}
      {%- endif -%}
      {%- if has_holiday -%}
        {%- assign h_lower = holiday_text | downcase -%}
        {%- assign h_icon = ic_holiday_generic -%}
        {%- if h_lower contains 'independence' -%}{%- assign h_icon = ic_fireworks -%}
        {%- elsif h_lower contains 'thanksgiving' -%}{%- assign h_icon = ic_turkey -%}
        {%- elsif h_lower contains 'christmas' -%}{%- assign h_icon = ic_tree -%}
        {%- elsif h_lower contains 'valentine' -%}{%- assign h_icon = ic_heart -%}
        {%- elsif h_lower contains 'halloween' -%}{%- assign h_icon = ic_pumpkin -%}
        {%- elsif h_lower contains 'easter' -%}{%- assign h_icon = ic_egg -%}
        {%- elsif h_lower contains 'mother' -%}{%- assign h_icon = ic_flower -%}
        {%- elsif h_lower contains 'father' -%}{%- assign h_icon = ic_necktie -%}
        {%- elsif h_lower contains 'patrick' -%}{%- assign h_icon = ic_clover -%}
        {%- elsif h_lower contains 'new year' -%}{%- assign h_icon = ic_sparkle -%}
        {%- endif -%}
      {%- endif -%}
      <div class="row {% if day.today %}is-today{% endif %}{% if day.month_start %} month-start{% endif %}{% if has_holiday %} has-holiday{% endif %}">
        {%- if has_holiday -%}
        {%- comment -%}
          The icon used to be pinned to a fixed point at the far right of the
          banner (position:absolute; right:14px), independent of how long the
          holiday label was -- a long label's centered text could run right
          into it, and a short one left it stranded far away. Rendering it as
          a normal flex sibling of the text (so it always sits immediately
          after the label, however long that label is) fixes both. Negative
          margins (rather than position:absolute) give it the vertical bleed
          without inflating the banner strip's own height to the icon's size.
        {%- endcomment -%}
        {%- assign h_v_dir = "up" -%}
        {%- if d_idx == 0 -%}{%- assign h_v_dir = "down" -%}{%- endif -%}
        {%- assign h_margin_style = "margin-top:-46px; margin-bottom:-4px;" -%}
        {%- if h_v_dir == "down" -%}{%- assign h_margin_style = "margin-bottom:-46px; margin-top:-4px;" -%}{%- endif -%}
        {%- assign h_rot = -8 -%}
        {%- assign h_jit = d_idx | modulo: 3 -%}
        {%- if h_jit == 1 -%}{%- assign h_rot = 7 -%}{%- elsif h_jit == 2 -%}{%- assign h_rot = -4 -%}{%- endif -%}
        <div class="holiday-banner">{{ holiday_text | upcase }}<div class="sticker" style="position:static; width:56px; height:56px; {{ h_margin_style }} transform:rotate({{ h_rot }}deg);">{{ h_icon }}</div></div>
        {%- endif -%}
        <div class="date-cell">
          <span class="dow">{% if day.month_start %}{{ day.month_name | slice: 0, 3 | upcase }}{% else %}{{ day.dow }}{% endif %}</span><span class="dnum">{{ day.d }}</span>
        </div>
        {%- for col in columns -%}
        {%- assign c_idx = forloop.index0 -%}
        {%- assign flat_idx = c_idx | times: days.size | plus: d_idx -%}
        {%- assign this_is_cont = span_is_cont_arr[flat_idx] -%}
        {%- assign this_span_len = span_len_arr[flat_idx] -%}
        {%- assign this_match_idx = span_match_idx_arr[flat_idx] | plus: 0 -%}
        {%- assign is_span_start = false -%}
        {%- if this_is_cont == "0" and this_span_len != "0" and this_span_len != "1" -%}{%- assign is_span_start = true -%}{%- endif -%}
        {%- assign is_span_member = false -%}
        {%- if this_is_cont == "1" or is_span_start -%}{%- assign is_span_member = true -%}{%- endif -%}
        <div class="cell{% if is_span_member %} has-span-bar{% endif %}">
          {%- assign cell_sticker_icon = "" -%}
          {%- for e in day.ev[col] -%}
            {%- if is_span_member and forloop.index0 == this_match_idx -%}
            {%- else -%}
            {%- assign e_lower = e[1] | downcase -%}
            {%- if cell_sticker_icon == "" -%}
              {%- if e[1] contains '!' -%}{%- assign cell_sticker_icon = ic_star -%}
              {%- elsif e_lower contains 'birthday' -%}{%- assign cell_sticker_icon = ic_cake -%}
              {%- elsif e_lower contains 'anniversary' -%}{%- assign cell_sticker_icon = ic_rings -%}
              {%- elsif e_lower contains 'vacation' or e_lower contains 'trip' or e_lower contains 'travel' -%}{%- assign cell_sticker_icon = ic_plane -%}
              {%- elsif e_lower contains 'baby shower' or e_lower contains 'due date' -%}{%- assign cell_sticker_icon = ic_stroller -%}
              {%- elsif e_lower contains 'visiting' or e_lower contains 'in town' or e_lower contains 'guests' -%}{%- assign cell_sticker_icon = ic_visit -%}
              {%- endif -%}
            {%- endif -%}
          <div class="evt">{% if e[0] and e[0] != '' %}<span class="t">{{ e[0] }}</span>{% endif %}{{ e[1] }}</div>
            {%- endif -%}
          {%- endfor -%}
          {%- if is_span_start -%}
            {%- assign span_title = day.ev[col][this_match_idx][1] | split: " (" | first | strip -%}
            {%- comment -%}
              A multi-day span suppresses its own event line on every day it
              covers (that's the whole point of the bar), which also skipped it
              past the per-event sticker-keyword check above -- so a real
              week-long "Family Vacation" would otherwise never get a sticker.
              Check the span's own title here too, once, on its start day only.
            {%- endcomment -%}
            {%- if cell_sticker_icon == "" -%}
              {%- assign span_title_lower = span_title | downcase -%}
              {%- if span_title contains '!' -%}{%- assign cell_sticker_icon = ic_star -%}
              {%- elsif span_title_lower contains 'birthday' -%}{%- assign cell_sticker_icon = ic_cake -%}
              {%- elsif span_title_lower contains 'anniversary' -%}{%- assign cell_sticker_icon = ic_rings -%}
              {%- elsif span_title_lower contains 'vacation' or span_title_lower contains 'trip' or span_title_lower contains 'travel' -%}{%- assign cell_sticker_icon = ic_plane -%}
              {%- elsif span_title_lower contains 'baby shower' or span_title_lower contains 'due date' -%}{%- assign cell_sticker_icon = ic_stroller -%}
              {%- elsif span_title_lower contains 'visiting' or span_title_lower contains 'in town' or span_title_lower contains 'guests' -%}{%- assign cell_sticker_icon = ic_visit -%}
              {%- endif -%}
            {%- endif -%}
            {%- assign top_pct = d_idx | times: 100.0 | divided_by: days.size -%}
            {%- assign span_len_num = this_span_len | plus: 0 -%}
            {%- assign height_pct = span_len_num | times: 100.0 | divided_by: days.size -%}
          <div class="span-bar" style="left:calc(var(--date-col-width) + (100% - var(--date-col-width)) * {{ c_idx }} / {{ columns.size }}); top:{{ top_pct }}%; height:{{ height_pct }}%;">{{ span_title }}</div>
          {%- endif -%}
          {%- if cell_sticker_icon != "" -%}
            {%- comment -%}
              Anchored off `.grid-body` using the same day/column-fraction calc()
              the span-bar uses -- NOT off `.cell` or `.row`, since giving either
              of those `position:relative` would hijack the span-bar's own
              containing block (it's nested inside `.cell` too) and break its
              multi-day height percentage. Always biased to the lower-right
              corner of the event, with small deterministic per-cell jitter on
              rotation/offset so it reads as hand-placed rather than mechanical.
              The last day/last column get a tighter bleed so the icon doesn't
              spill into the footer strip or off the edge of the canvas.
            {%- endcomment -%}
            {%- assign jitter_idx = d_idx | times: 31 | plus: c_idx | times: 17 | modulo: 5 -%}
            {%- case jitter_idx -%}
              {%- when 0 -%}{%- assign rot = -9 -%}{%- assign dx = 4 -%}{%- assign dy = -3 -%}
              {%- when 1 -%}{%- assign rot = 6 -%}{%- assign dx = 9 -%}{%- assign dy = 2 -%}
              {%- when 2 -%}{%- assign rot = -5 -%}{%- assign dx = 1 -%}{%- assign dy = -6 -%}
              {%- when 3 -%}{%- assign rot = 10 -%}{%- assign dx = 7 -%}{%- assign dy = -1 -%}
              {%- else -%}{%- assign rot = -3 -%}{%- assign dx = 5 -%}{%- assign dy = -4 -%}
            {%- endcase -%}
            {%- assign bleed_px = 34 -%}
            {%- if d_idx == last_day_idx -%}{%- assign bleed_px = 44 -%}{%- endif -%}
            {%- assign anchor_frac = "0.86" -%}
            {%- assign last_col_idx = columns.size | minus: 1 -%}
            {%- if c_idx == last_col_idx -%}{%- assign anchor_frac = "0.74" -%}{%- endif -%}
            {%- assign row_bottom_pct = d_idx | plus: 1 | times: 100.0 | divided_by: days.size -%}
            {%- assign top_style = "top:calc(" | append: row_bottom_pct | append: "% - " | append: bleed_px | append: "px + " | append: dy | append: "px);" -%}
            {%- assign left_style = "left:calc(var(--date-col-width) + (100% - var(--date-col-width)) * (" | append: c_idx | append: " + " | append: anchor_frac | append: ") / " | append: columns.size | append: " - 25px + " | append: dx | append: "px);" -%}
          <div class="sticker" style="width:50px; height:50px; {{ top_style }} {{ left_style }} transform:rotate({{ rot }}deg);">{{ cell_sticker_icon }}</div>
          {%- endif -%}
        </div>
        {%- endfor -%}
      </div>
      {%- endfor -%}
    </div>
  </div>

  <!-- ============ FOOTER ============ -->
  <div class="footer">
    <div>Updated {{ meta.updated }}</div>
    <div class="right"><span>{{ meta.device_label }}</span><span class="dev-glyph"></span></div>
  </div>

</div>
